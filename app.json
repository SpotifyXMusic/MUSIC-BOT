{
  "name": "MusicBot",
  "description": "Advanced Telegram Music Bot - YouTube Audio/Video Streaming",
  "keywords": ["telegram", "music", "bot", "python", "youtube"],
  "env": {
    "API_ID": {
      "description": "Your Telegram API ID from my.telegram.org",
      "required": true
    },
    "API_HASH": {
      "description": "Your Telegram API Hash from my.telegram.org",
      "required": true
    },
    "BOT_TOKEN": {
      "description": "Bot Token from @BotFather",
      "required": true
    },
    "STRING_SESSION": {
      "description": "Pyrogram String Session for userbot (voice calls)",
      "required": true
    },
    "MONGO_DB_URI": {
      "description": "MongoDB connection URI",
      "required": true
    },
    "OWNER_ID": {
      "description": "Your Telegram User ID",
      "required": true
    },
    "BOT_NAME": {
      "description": "Display name of the bot",
      "value": "MusicBot"
    },
    "OWNER_NAME": {
      "description": "Your name",
      "value": "Owner"
    },
    "BOT_USERNAME": {
      "description": "Bot username without @",
      "required": true
    },
    "SUPPORT_GROUP": {
      "description": "Support group link",
      "value": "https://t.me/"
    },
    "SUPPORT_CHANNEL": {
      "description": "Channel link",
      "value": "https://t.me/"
    },
    "COOKIES_URL": {
      "description": "YouTube cookies URL from batbin.me (optional)",
      "value": ""
    },
    "DURATION_LIMIT": {
      "description": "Max song duration in minutes",
      "value": "180"
    },
    "LOG_GROUP_ID": {
      "description": "Telegram group ID for logs (optional)",
      "value": "0"
    }
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "free"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ]
}
