#!/bin/bash
echo "=============================="
echo "  MusicBot Setup"
echo "=============================="

# Install requirements
pip install -r requirements.txt

# Create needed dirs
mkdir -p downloads cookies

# Copy env sample
if [ ! -f .env ]; then
    cp .env.sample .env
    echo "[OK] .env file created. Please fill in your values."
else
    echo "[OK] .env already exists."
fi

echo ""
echo "Setup complete! Now:"
echo "1. Edit .env with your bot credentials"
echo "2. Run: python __main__.py"
echo "=============================="
